PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=https://leightsong.github.io
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct
VITE_API_BASE_URL=https://your-newsflow-api.example.com
VITE_BASE_PATH=/your-repo-name/
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=your_chat_deployment_name_here
AZURE_OPENAI_API_VERSION=2024-10-21
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_speech_region_here
AZURE_SPEECH_VOICE=en-US-AndrewMultilingualNeural
AZURE_SPEECH_VOICES=en-US-JennyNeural,en-US-GuyNeural,en-US-AriaNeural,en-US-DavisNeural,en-US-JaneNeural,en-US-TonyNeural,en-US-SaraNeural,en-US-JasonNeural
AZURE_SPEECH_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3